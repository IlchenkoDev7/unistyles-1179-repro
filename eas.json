{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "buildArtifactPaths": ["ios/build/*"],
      "ios": {
        "simulator": false
      }
    },
    "preview-sim": {
      "distribution": "internal",
      "buildArtifactPaths": ["ios/build/*"],
      "ios": {
        "simulator": true
      }
    }
  }
}
